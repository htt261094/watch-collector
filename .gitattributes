# Normalize line endings to LF in the repository for all text files.
* text=auto eol=lf

# Explicitly treat known source/text types as LF text.
*.dart   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.kts    text eol=lf
*.kt     text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.properties text eol=lf
*.gradle text eol=lf

# Binary assets — never touch.
*.png    binary
*.jar    binary
*.keystore binary
*.jks    binary
